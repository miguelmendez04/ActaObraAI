<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<diagram program="umlet" version="15.0.0">
  <zoom_level>10</zoom_level>
  
  <!-- Usuarios -->
  <element>
    <id>UMLActor</id>
    <coordinates><x>20</x><y>100</y><w>100</w><h>100</h></coordinates>
