    <coordinates><x>460</x><y>160</y><w>220</w><h>70</h></coordinates>
    <panel_attributes>&lt;&lt;n8n Workflow&gt;&gt;
Procesamiento Empresa B
(Integra Gemini Audio/Vision)</panel_attributes>
    <additional_attributes/>
  </element>

  <!-- Backend FastAPI -->
  <element>
    <id>UMLPackage</id>
    <coordinates><x>760</x><y>20</y><w>300</w><h>460</h></coordinates>
    <panel_attributes>Backend FastAPI (Hugging Face)
--</panel_attributes>
    <additional_attributes/>
  </element>

  <element>
    <id>UMLClass</id>
    <coordinates><x>790</x><y>80</y><w>230</w><h>90</h></coordinates>
    <panel_attributes>&lt;&lt;Ingesta Automática&gt;&gt;
POST /api/n8n/ingest
POST /api/n8n/ingest-pdf
(Requiere ?token=...)</panel_attributes>
    <additional_attributes/>
  </element>

  <element>
    <id>UMLClass</id>
    <coordinates><x>790</x><y>220</y><w>230</w><h>80</h></coordinates>
    <panel_attributes>&lt;&lt;Vector Database&gt;&gt;
ChromaDB
- collection: actas_company_A
- collection: actas_company_B</panel_attributes>
    <additional_attributes/>
  </element>

  <element>
    <id>UMLClass</id>
    <coordinates><x>790</x><y>360</y><w>230</w><h>90</h></coordinates>
    <panel_attributes>&lt;&lt;API Frontend&gt;&gt;
POST /api/ask (Gemini RAG)
GET /api/documents
(Protegido con OAuth2 Bearer)</panel_attributes>
    <additional_attributes/>
  </element>

  <!-- Frontend React -->
  <element>
    <id>UMLClass</id>
    <coordinates><x>330</x><y>360</y><w>240</w><h>100</h></coordinates>
    <panel_attributes>&lt;&lt;Frontend React + Vite&gt;&gt;
WebApp ActaObra IA
- Interfaz Multi-Chat
- DB View con Polling (10s)
- Toast Notifications</panel_attributes>
    <additional_attributes/>
  </element>

